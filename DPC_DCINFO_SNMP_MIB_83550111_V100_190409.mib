    SYNTAX INTEGER(0..59)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "Minute of installation date.
         The actual value = The receive data.
         "  
    ::= { characteristic 12 }
    -- 1.3.6.1.4.1.39553.10.3.12.13
    installationSecond OBJECT-TYPE
    SYNTAX INTEGER(0..59)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "Second of installation date.
         The actual value = The receive data.
         "  
    ::= { characteristic 13 }
    -- 1.3.6.1.4.1.39553.10.3.12.14
    totalRunTime OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION 
        "Total run time of controller.
         The actual value = The receive data/100.
         The unit of actual value is hour.
         "  
    ::= { characteristic 14 }
