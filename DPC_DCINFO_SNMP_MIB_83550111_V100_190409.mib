------------------------------------------------------------
-- Battery information table { dcAnalog 1073 }
------------------------------------------------------------

batteryInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF BatteryInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "
        Table holding information about the currently battery."
    ::= { dcAnalog 1073 }

batteryInfoEntry OBJECT-TYPE
    SYNTAX BatteryInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "
        An entry (conceptual row) in the batteryInfoTable."
    INDEX { batteryIndex }
    ::= { batteryInfoTable 1 }

BatteryInfoEntry ::= SEQUENCE {
        batteryIndex INTEGER,
        batteryCurrent INTEGER,
        batteryVoltage INTEGER,
        batterySOC INTEGER,
        middleVoltage INTEGER,
        totalCapacity INTEGER,
        batteryTemperature INTEGER,
        cannotCharge INTEGER
    }

    batteryIndex OBJECT-TYPE
    SYNTAX INTEGER {
        battery1    (1),
        battery2    (2),
        battery3    (3),
        battery4    (4),
        battery5    (5),
        battery6    (6),
        battery7    (7),
        battery8    (8)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        The unique sequence number of battery.
        battery1    (1),
        battery2    (2),
        battery3    (3),
        battery4    (4),
        battery5    (5),
        battery6    (6),
        battery7    (7),
        battery8    (8),
        "
    ::= { batteryInfoEntry 1 }

    batteryCurrent OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Battery current.
         The actual value = The receive data/100.
         The unit of actual value is ampere"
    ::= { batteryInfoEntry 2 }
    
    batteryVoltage OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Battery voltage.
         The actual value = The receive data/100.
         The unit of actual value is volt"
    ::= { batteryInfoEntry 3 }
    
    batterySOC OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Battery SOC.
         The actual value = The receive data/100.
         The unit of actual value is percent"
    ::= { batteryInfoEntry 4 }
    
    middleVoltage OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Battery middle voltage.
         The actual value = The receive data/100.
         The unit of actual value is volt"
    ::= { batteryInfoEntry 5 }
    
    totalCapacity OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "
        Battery total capacity.
         The actual value = The receive data/100.
         The unit of actual value is AH"
    ::= { batteryInfoEntry 6 }
    
    batteryTemperature OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Battery temperature.
         The actual value = The receive data/100.
         The unit of actual value is degree centigrade.
         If  receive value is greater than 10000 or less than -5000,temperature is invalid"
    ::= { batteryInfoEntry 7 }
    
    cannotCharge OBJECT-TYPE
    SYNTAX INTEGER {
        normal (0),
        alarm (1)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Battery can not charge alarm state.
         normal (0),
        alarm (1)"
    ::= { batteryInfoEntry 8 }

------------------------------------------------------------
-- EX temperature information table { dcAnalog 1074 }
------------------------------------------------------------

exTemperatureTable OBJECT-TYPE
    SYNTAX SEQUENCE OF ExTemperatureEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "
        Table holding information of temperature about the SC320."
    ::= { dcAnalog 1074 }

exTemperatureEntry OBJECT-TYPE
    SYNTAX ExTemperatureEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "
        An entry (conceptual row) in the exTemperatureTable."
    INDEX { batteryIndex }
    ::= { exTemperatureTable 1 }

ExTemperatureEntry ::= SEQUENCE {
        sc320Index INTEGER,
        temperature_1 INTEGER,
        temperature_2 INTEGER,
        temperature_3 INTEGER,
        humidity INTEGER
    }

    sc320Index OBJECT-TYPE
    SYNTAX INTEGER {
        sc320-1 (1),
        sc320-2 (2),
        sc320-3 (3),
        sc320-4 (4),
        sc320-5 (5)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        The unique sequence number of SC320.
        sc320-1 (1),
        sc320-2 (2),
        sc320-3 (3),
        sc320-4 (4),
        sc320-5 (5)
        "
    ::= { exTemperatureEntry 1 }

    temperature_1 OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Temperature 1.
         The actual value = The receive data/100.
         The unit of actual value is degree centigrade.
         If  receive value is greater than 10000 or less than -5000,temperature is invalid"
    ::= { exTemperatureEntry 2 }
    
    temperature_2 OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Temperature 2.
         The actual value = The receive data/100.
         The unit of actual value is degree centigrade.
         If  receive value is greater than 10000 or less than -5000,temperature is invalid"
    ::= { exTemperatureEntry 3 }
    
    temperature_3 OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Temperature 3.
         The actual value = The receive data/100.
         The unit of actual value is degree centigrade.
         If  receive value is greater than 10000 or less than -5000,temperature is invalid"
    ::= { exTemperatureEntry 4 }
    
    humidity OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Humidity.
         The actual value = The receive data/100.
         The unit of actual value is %.
         If  receive value is greater than 10000 or less than 0,temperature is invalid"
    ::= { exTemperatureEntry 5 }
    
