------------------------------------------------------------
-- DC branch information table { dcAnalog 1072 }
------------------------------------------------------------

dcBranchInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF DCBranchInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "
        Table holding information about the currently DC branch."
    ::= { dcAnalog 1072 }

dcBranchInfoEntry OBJECT-TYPE
    SYNTAX DCBranchInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "
        An entry (conceptual row) in the dcBranchInfoTable."
    INDEX { dcBranchIndex }
    ::= { dcBranchInfoTable 1 }

DCBranchInfoEntry ::= SEQUENCE {
        dcBranchIndex INTEGER,
        dcBranchcurrent INTEGER,
        slightOverCurrent INTEGER,
        severeOverCurrent INTEGER
    }

    dcBranchIndex OBJECT-TYPE
    SYNTAX INTEGER {
        dcBranch1   (1),
        dcBranch2   (2),
        dcBranch3   (3),
        dcBranch4   (4),
        dcBranch5   (5),
        dcBranch6   (6),
        dcBranch7   (7),
        dcBranch8   (8),
        dcBranch9   (9),
        dcBranch10  (10),
        dcBranch11  (11),
        dcBranch12  (12),
        dcBranch13  (13),
        dcBranch14  (14),
        dcBranch15  (15),
        dcBranch16  (16),
        dcBranch17  (17),
        dcBranch18  (18),
        dcBranch19  (19),
        dcBranch20  (20),
        dcBranch21  (21),
        dcBranch22  (22),
        dcBranch23  (23),
        dcBranch24  (24),
        dcBranch25  (25),
        dcBranch26  (26),
        dcBranch27  (27),
        dcBranch28  (28),
        dcBranch29  (29),
        dcBranch30  (30),
        dcBranch31  (31),
        dcBranch32  (32),
        dcBranch33  (33),
        dcBranch34  (34),
        dcBranch35  (35),
        dcBranch36  (36),
