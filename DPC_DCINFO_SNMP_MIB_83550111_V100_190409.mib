-- System Parameter Setting{ dcDistribution 4 }
------------------------------------------------------------        
  -- 1.3.6.1.4.1.39553.10.3.4
    systemParameter OBJECT IDENTIFIER ::= { dcDistribution 4 }

  -- 1.3.6.1.4.1.39553.10.3.4.1
    timeZone OBJECT-TYPE
    SYNTAX INTEGER (0..36)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "System time zone."
    ::= { systemParameter 1 }
  -- 1.3.6.1.4.1.39553.10.3.4.2
    timeFormat OBJECT-TYPE
    SYNTAX INTEGER {
        yearMonthDay (0),
        monthDayYear (1),
        dayMonthYear (2)
    }
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "System time display format.
         0=Y-M-D;
         1=M-D-Y;
         2=D-M-Y."
    ::= { systemParameter 2 }
  -- 1.3.6.1.4.1.39553.10.3.4.3
    dcCabinetNumber OBJECT-TYPE
    SYNTAX INTEGER (0..255)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "DC cabinet number."
    ::= { systemParameter 3 }
  -- 1.3.6.1.4.1.39553.10.3.4.4
