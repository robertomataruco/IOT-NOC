--  Characteristic string for DC Distribution { dcDistribution 12 }
------------------------------------------------------------    
    -- 1.3.6.1.4.1.39553.10.3.12
    characteristic OBJECT IDENTIFIER ::= { dcDistribution 12 }

  -- 1.3.6.1.4.1.39553.10.3.12.1
    companyName OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..39))
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "The name of manufacturer."
    ::= { characteristic 1 }
  -- 1.3.6.1.4.1.39553.10.3.12.2
    companyUrl OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..39))
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "The website of manufacturer."
    ::= { characteristic 2 }    
  -- 1.3.6.1.4.1.39553.10.3.12.3
    productModel OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..31))
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "The product Model of controller."
    ::= { characteristic 3 }
  -- 1.3.6.1.4.1.39553.10.3.12.4
    contactPhone OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..19))
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "The contact phone number of manufacturer."
    ::= { characteristic 4 }
  -- 1.3.6.1.4.1.39553.10.3.12.5
    companyAddress OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..99))
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "The contact address of manufacturer."
    ::= { characteristic 5 }
  -- 1.3.6.1.4.1.39553.10.3.12.6
    productBarcode OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..20))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION 
        "The barcode of controller."
    ::= { characteristic 6 }
  -- 1.3.6.1.4.1.39553.10.3.12.7
    softwareVersion OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..19))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION 
        "The software version of controller."
    ::= { characteristic 7 }
    -- 1.3.6.1.4.1.39553.10.3.12.8
    installationYear OBJECT-TYPE
    SYNTAX INTEGER(0..2100)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "Year of installation date.
         The actual value = The receive data.
         "  
    ::= { characteristic 8 }
    -- 1.3.6.1.4.1.39553.10.3.12.9
    installationMonth OBJECT-TYPE
    SYNTAX INTEGER(1..12)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "Month of installation date.
         The actual value = The receive data.
         "  
    ::= { characteristic 9 }
    -- 1.3.6.1.4.1.39553.10.3.12.10
    installationDay OBJECT-TYPE
    SYNTAX INTEGER(1..31)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "Day of installation date.
         The actual value = The receive data.
         "  
    ::= { characteristic 10 }
    -- 1.3.6.1.4.1.39553.10.3.12.11
    installationHour OBJECT-TYPE
    SYNTAX INTEGER(0..23)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "Hour of installation date.
         The actual value = The receive data.
         "  
    ::= { characteristic 11 }
    -- 1.3.6.1.4.1.39553.10.3.12.12
