		ecoParameter OBJECT IDENTIFIER ::= { dcDistribution 16 }
  -- 1.3.6.1.4.1.39553.10.3.16.1
	ecoMode OBJECT-TYPE
	SYNTAX INTEGER {
		intelligentMode (0),
		timeMode (1),
		highEfficiencyMode (2)
	}
	MAX-ACCESS read-write
	STATUS current
	DESCRIPTION 
		"ECO running mode."
	::= { ecoParameter 1 }
  -- 1.3.6.1.4.1.39553.10.3.16.101
	acdcRectifierECOEnable OBJECT-TYPE
	SYNTAX INTEGER {
		disable (0),
		enable (1)
	}
	MAX-ACCESS read-write
	STATUS current
	DESCRIPTION 
		"ACDC rectifier ECO enable."
	::= { ecoParameter 101 }
  -- 1.3.6.1.4.1.39553.10.3.16.102
	acdcRectifierPhaseBalanceEnable OBJECT-TYPE
	SYNTAX INTEGER {
		disable (0),
		enable (1)
	}
	MAX-ACCESS read-write
	STATUS current
	DESCRIPTION 
		"AC input phase balance enable."
	::= { ecoParameter 102 }
  -- 1.3.6.1.4.1.39553.10.3.16.103
	acdcRectifierECODelay OBJECT-TYPE
	SYNTAX INTEGER (0..9900)
	MAX-ACCESS read-write
	STATUS current
	DESCRIPTION 
		"ACDC rectifier ECO delay.
		 The actual value = The set or receive data / 100.
		 The unit of actual value is hour."
	::= { ecoParameter 103 }
  -- 1.3.6.1.4.1.39553.10.3.16.104
	acdcRectifierMinimumQuantity OBJECT-TYPE
	SYNTAX INTEGER (1..255)
	MAX-ACCESS read-write
	STATUS current
	DESCRIPTION 
		"ACDC rectifier minimum quantity.
		 The actual value = The set or receive data.
		 "
	::= { ecoParameter 104 }
  -- 1.3.6.1.4.1.39553.10.3.16.105
	acdcRectifierPowerOnLoadRate OBJECT-TYPE
	SYNTAX INTEGER (10000..95000)
	MAX-ACCESS read-write
	STATUS current
	DESCRIPTION 
		"The load rate for control power on the ACDC rectifier for ECO function.
		 The actual value = The set or receive data / 1000.
		 The unit of actual value is %."
	::= { ecoParameter 105 }
  -- 1.3.6.1.4.1.39553.10.3.16.106
	acdcRectifierOnOffPeriodECO OBJECT-TYPE
	SYNTAX INTEGER (1..72000)
	MAX-ACCESS read-write
	STATUS current
	DESCRIPTION 
		"The period for control on or off the ACDC rectifier for ECO function.
		 The actual value = The set or receive data / 100.
		 The unit of actual value is hour."
	::= { ecoParameter 106 }
  -- 1.3.6.1.4.1.39553.10.3.16.107
	acdcRectifierPowerOffLoadRate OBJECT-TYPE
	SYNTAX INTEGER (0..85000)
	MAX-ACCESS read-write
	STATUS current
	DESCRIPTION 
		"The load rate for control power off the ACDC rectifier for ECO function.
		 The actual value = The set or receive data / 1000.
		 The unit of actual value is %."
	::= { ecoParameter 107 }
  -- 1.3.6.1.4.1.39553.10.3.16.108
	acdcRectifierManualStartTest OBJECT-TYPE
	SYNTAX INTEGER {
		stop (0),
		start (1)
	}
	MAX-ACCESS read-write
	STATUS current
	DESCRIPTION 
		"ACDC rectifier manual start test."
	::= { ecoParameter 108 }
  -- 1.3.6.1.4.1.39553.10.3.16.109
	acdcRectifierManualTestResult OBJECT-TYPE
	SYNTAX INTEGER {
		fail (0),
		ok (1),
		running (2),
		autoMode (3)
	}
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION 
		"ACDC rectifier manual test result."
	::= { ecoParameter 109 }
