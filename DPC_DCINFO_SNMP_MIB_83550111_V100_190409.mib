    ::= { dcAlarmStatus 36 }
  -- 1.3.6.1.4.1.39553.10.3.2.43
    dcSystemAlarm OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION     
        "The alarm for DC system.
         The bit0 to bit31 for the receive data means the DC system alarm status.
         The value 1 means alarm happen for the each bit. 
         And the value of 0 means no alarm for each bit.
         bit0 = dcOverVoltage,
         bit1 = dcHighVoltage,
         bit2 = dcLowVoltage,
         bit3 = dcUnderVoltage,
         bit4 = dcLoadBranchSevereOverCurrent,
         bit5 = dcLoadBranchSlightOverCurrent,   
         bit6 = ecoRunning,
         bit7 = busInsulationFault,
         bit8 = loadBranchInsulationFault,
         bit9 = dcTotalLoadSlightOverCurrent,
         bit10 = dcTotalLoadSevereOverCurrent,
         bit11 = systemSPDFault,
         bit12 = systemTotalAlarm,
         bit13-bit31 = Reserve."
    ::= { dcAlarmStatus 43 }
  -- 1.3.6.1.4.1.39553.10.3.2.44
    batteryAlarm OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION     
        "The alarm for battery.
