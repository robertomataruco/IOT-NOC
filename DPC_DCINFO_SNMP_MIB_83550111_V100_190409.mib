alarmTime OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Date and time when event occured (local time), including
        timezone if supported by controller."
    ::= { activeAlarmEntry 2 }

alarmLevel OBJECT-TYPE
    SYNTAX Integer32 {
        minor (0),
        major (1),
        critical (2)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        The severity of the alarm. One of
        (0) minor - MI, lowest level of alarm severity
        (1) major - MA
        (2) critical - CA, highest level of alarm severity"
    ::= { activeAlarmEntry 3 }

alarmType OBJECT-TYPE
    SYNTAX Integer32 {
        notUsed (0),
        acAlarm (1),
        dcAlarm (2),
        communicationAlarm (3),
        lvdAlarm (4),
        batteryFuseAlarm (5),
        batteryNFuseAlarm (6),
        batteryAlarm (7),
        loadFuseAlarm (8),
        environmentTemperatureAlarm (9),
        batteryTemperatureAlarm (10),
        digitalInputAlarm (11),
        rectifierAlarm (12),
        solarControllerAlarm (13),
        windControllerAlarm (14),
        inverterAlarm (15),
        dcdcConverterAlarm (16),
        slightOverCurrentAlarm (17),
        severeOverCurrentAlarm (18),
        bmsAlarm (19),
        plcAirthmeticAlarm (20),
        plcLogicAlarm (21),
        plcGroupAlarm (22),
        bmmAlarm (23),
        userAlarm(24),
        dgAlarm(25),
        sc350Alarm(26)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Alarm type, i.e. an integer specifying the type of alarm.
        notUsed (0),
        acAlarm (1),
        dcAlarm (2),
        communicationAlarm (3),
        lvdAlarm (4),
        batteryFuseAlarm (5),
        batteryNFuseAlarm (6),
        batteryAlarm (7),
        loadFuseAlarm (8),
        environmentTemperatureAlarm (9),
        batteryTemperatureAlarm (10),
        digitalInputAlarm (11),
        rectifierAlarm (12),
        solarControllerAlarm (13),
        windControllerAlarm (14),
        inverterAlarm (15),
        dcdcConverterAlarm (16),
        slightOverCurrentAlarm (17),
        severeOverCurrentAlarm (18),
        bmsAlarm (19),
        plcAirthmeticAlarm (20),
        plcLogicAlarm (21),
        plcGroupAlarm (22),
        bmmAlarm (23),
        userAlarm(24),
        dgAlarm(25),
        sc350Alarm(26)"
    ::= { activeAlarmEntry 4 }
    
alarmRelateDOPosition OBJECT-TYPE
    SYNTAX Integer32 {
        notUsed (0),
        controller (1),
        extendDOBorad1 (2),
        extendDOBorad2 (3),
        extendDOBorad3 (4),
        extendDOBorad4 (5),
        extendDOBorad5 (6)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        The position of the relay-out for the alarm.
        notUsed (0),
        controller (1),
        extendDOBorad1 (2),
        extendDOBorad2 (3),
        extendDOBorad3 (4),
        extendDOBorad4 (5),
        extendDOBorad5 (6)"
    ::= { activeAlarmEntry 5 }
    
alarmRelateDO OBJECT-TYPE
    SYNTAX Integer32 {
        relayOut1 (0),
        relayOut2 (1),
        relayOut3 (2),
        relayOut4 (3),
        relayOut5 (4),
        relayOut6 (5),
        relayOut7 (6),
        relayOut8 (7),
        relayOut9 (8),
        relayOut10 (9),
        relayOut11 (10),
        relayOut12 (11),
        relayOut13 (12),
        relayOut14 (13),
        relayOut15 (14),
        relayOut16 (15)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        The relay-out number for the alarm.
        relayOut1 (0),
        relayOut2 (1),
        relayOut3 (2),
        relayOut4 (3),
        relayOut5 (4),
        relayOut6 (5),
        relayOut7 (6),
        relayOut8 (7),
        relayOut9 (8),
        relayOut10 (9),
        relayOut11 (10),
        relayOut12 (11),
        relayOut13 (12),
        relayOut14 (13),
        relayOut15 (14),
        relayOut16 (15)"
    ::= { activeAlarmEntry 6 }
    
alarmBuzzer OBJECT-TYPE
    SYNTAX Integer32 {
        silent (0),
        sound (1)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        The alarm configuration for the buzzer.One of
        (0) silent - no sound for alarm
        (1) sound - sound for alarm"
    ::= { activeAlarmEntry 7 }
    
alarmMoudleID OBJECT-TYPE
    SYNTAX Integer32 {
        notMoudleAlarm (0)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        The moudle ID number of the moudle.This is only for 
        rectifierAlarm, solarControllerAlarm, windControllerAlarm, 
        inverterAlarm, dcdcConverterAlarm.
        (0) not the moudle alarm
        (1..128) the moudle ID number of the moudle"
    ::= { activeAlarmEntry 8 }

alarmStatusChange OBJECT-TYPE
    SYNTAX Integer32{
        deactivated (0),
        activated (1)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        The status of alarm. One of
        (0) deactivated
        (1) activated"
    ::= { activeAlarmEntry 9 }
alarmName OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION 
        "Alarm name."
    ::= { activeAlarmEntry 10 }
------------------------------------------------------------
-- Events/traps { systemAlarm 3 }
------------------------------------------------------------

systemTraps OBJECT IDENTIFIER ::= { systemAlarm 3 }

alarmTrap NOTIFICATION-TYPE
    OBJECTS {
        alarmIndex,
        alarmTime,
        alarmLevel,
        alarmType,
        alarmRelateDOPosition,
        alarmRelateDO,
        alarmBuzzer,
        alarmMoudleID,
        alarmStatusChange
    }
    STATUS current
    DESCRIPTION "
        An alarm trap is sent when an alarm occurs (activated) or
        returns to normal state (deactivated). Alarm traps are logged
        in alarmTrapTable. Variables in this trap:
        * alarmIndex - The unique sequence number of this alarm trap.
        * alarmTime - Date and time when event occured (local time),
              including timezone if supported by controller.
        * alarmLevel - Integer describing the severity of the alarm.
        * alarmType - Integer indicating type of alarm.
        * alarmRelateDOPosition - The position of the relay-out for the alarm.
        * alarmRelateDO - The relay-out number for the alarm.
        * alarmBuzzer - The alarm configuration for the buzzer.
        * alarmMoudleID - The moudle ID number of the moudle.
        * alarmStatusChange - The status of alarm."
    ::= { systemTraps 1 }


alarmActiveTrap NOTIFICATION-TYPE
    OBJECTS {
        alarmIndex,
        alarmTime,
        alarmLevel,
        alarmType,
        alarmRelateDOPosition,
        alarmRelateDO,
        alarmBuzzer,
        alarmMoudleID
    }
    STATUS current
    DESCRIPTION "
        An alarm trap is sent when an alarm occurs (activated).
        Alarm traps are logged in alarmTrapTable. Variables in this trap:
        * alarmIndex - The unique sequence number of this alarm trap.
        * alarmTime - Date and time when event occured (local time),
              including timezone if supported by controller.
        * alarmLevel - Integer describing the severity of the alarm.
        * alarmType - Integer indicating type of alarm.
        * alarmRelateDOPosition - The position of the relay-out for the alarm.
        * alarmRelateDO - The relay-out number for the alarm.
        * alarmBuzzer - The alarm configuration for the buzzer.
        * alarmMoudleID - The moudle ID number of the moudle."
    ::= { systemTraps 2 }
    
alarmCeaseTrap NOTIFICATION-TYPE
    OBJECTS {
        alarmIndex,
        alarmTime,
        alarmLevel,
        alarmType,
        alarmRelateDOPosition,
        alarmRelateDO,
        alarmBuzzer,
        alarmMoudleID
    }
    STATUS current
    DESCRIPTION "
        An alarm trap is sent when an alarm returns to normal state (clear, deactivated). 
        Alarm traps are logged in alarmTrapTable. Variables in this trap:
        * alarmIndex - The unique sequence number of this alarm trap.
        * alarmTime - Date and time when event occured (local time),
              including timezone if supported by controller.
        * alarmLevel - Integer describing the severity of the alarm.
        * alarmType - Integer indicating type of alarm.
        * alarmRelateDOPosition - The position of the relay-out for the alarm.
        * alarmRelateDO - The relay-out number for the alarm.
        * alarmBuzzer - The alarm configuration for the buzzer.
        * alarmMoudleID - The moudle ID number of the moudle."
    ::= { systemTraps 3 }  
    
------------------------------------------------------------
-- End of MIB definitions
------------------------------------------------------------

END
