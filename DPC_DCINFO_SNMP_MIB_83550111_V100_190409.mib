---System Alarm
systemAlarm OBJECT IDENTIFIER ::= { dpcDistributedPower 4 }

------------------------------------------------------------
-- Alarm trap counter { systemAlarm 1 }
------------------------------------------------------------

totalAlarmNumber OBJECT-TYPE
    SYNTAX Counter32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        The total number of the current alarm."
    ::= { systemAlarm 1 }
        
------------------------------------------------------------
-- Active Alarm table { systemAlarm 2 }
------------------------------------------------------------

activeAlarmTable OBJECT-TYPE
    SYNTAX SEQUENCE OF ActiveAlarmEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "
        Table holding information about the currently active alarms."
    ::= { systemAlarm 2 }

activeAlarmEntry OBJECT-TYPE
    SYNTAX ActiveAlarmEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "
        An entry (conceptual row) in the alarmTrapTable."
    INDEX { alarmIndex }
    ::= { activeAlarmTable 1 }

ActiveAlarmEntry ::= SEQUENCE {
    alarmIndex Counter32,
    alarmTime DisplayString,
    alarmLevel Integer32,
    alarmType Integer32,
    alarmRelateDOPosition Integer32,
    alarmRelateDO Integer32,
    alarmBuzzer Integer32,
    alarmMoudleID Integer32,
    alarmStatusChange Integer32,
    alarmName DisplayString,
    }

alarmIndex OBJECT-TYPE
    SYNTAX Counter32 {
        ac1SlightOverCurrent (0),
        ac1SevereOvercurrent  (1),
        ac1OverVoltage (2),
        ac1UnderVoltage (3),
        ac1Phasefailure (4),
        ac1Mainsfailure (5),
        ac1HighFrequency  (6),
        ac1LowFrequency  (7),
        ac2SlightOverCurrent (8),
        ac2SevereOverCurrent (9),
        ac2OverVoltage (10),
        ac2UnderVoltage (11),
        ac2LosePhase (12),
        ac2Mainsfailure (13),
        ac2FreqHigh (14),
        ac2FreqLow (15),
        acSPDFault (16),
        acSPDMCBFault (17),
        acTrip (18),
        acSampleBoardFault (19),
        acControllerEEPROMFault (20),
        dg1Repairing (21),
        dg2Repairing (22),

        dcOverVoltage (86),
        dcHighVoltage (87),
        dcLowVoltage (88),
        dcUnderVoltage (89),
        ecoRunning (90),
        busInsulationFault (91),
        loadBranchInsulationFault (92),
        dcTotalLoadSlightOverCurrent (93),
        dcTotalLoadSevereOverCurrent (94),
        systemSPDFault (95),
        systemTotalAlarm (96),
        
        sc210-1CommunicationFault (156),
        sc210-2CommunicationFault (157),
        sc501-1CommunicationFault (158),
        sc501-2CommunicationFault (159),
        sc501-3CommunicationFault (160),
        sc501-4CommunicationFault (161),
        sc310-1CommunicationFault (162),
        sc310-2CommunicationFault (163),
        sc310-3CommunicationFault (164),
        sc340-1CommunicationFault (165),
        sc340-2CommunicationFault (166),
        sc340-3CommunicationFault (167),
        sc200-1CommunicationFault (168),
        sc200-2CommunicationFault (169),
        sc200-3CommunicationFault (170),
        sc920-1CommunicationFault (171),
        sc920-2CommunicationFault (172),
        sc320-1CommunicationFault (173),
        sc320-2CommunicationFault (174),
        sc320-3CommunicationFault (175),
        sc320-4CommunicationFault (176),
        sc320-5CommunicationFault (177),
        sc330-1CommunicationFault (178),
        sc330-2CommunicationFault (179),
        sc330-3CommunicationFault (180),
        sc330-4CommunicationFault (181),
        sc330-5CommunicationFault (182),
        sc930-1CommunicationFault (183),
        sc930-2CommunicationFault (184),
        sc900-1CommunicationFault (185),
        sc900-2CommunicationFault (186),
        sc900-3CommunicationFault (187),
        sc900-4CommunicationFault (188),
        bms1CommunicationFault (189),
        bms2CommunicationFault (190),
        bms3CommunicationFault (191),
        bms4CommunicationFault (192),
        bms5CommunicationFault (193),
        bms6CommunicationFault (194),
        bms7CommunicationFault (195),
        bms8CommunicationFault (196),
        bms9CommunicationFault (197),
        bms10CommunicationFault (198),
        bms11CommunicationFault (199),
        bms12CommunicationFault (200),
        bms13CommunicationFault (201),
        bms14CommunicationFault (202),
        bms15CommunicationFault (203),
        bms16CommunicationFault (204),
        bms17CommunicationFault (205),
        bms18CommunicationFault (206),
        bms19CommunicationFault (207),
        bms20CommunicationFault (208),
        temperatureSensor1NotAssemble (209),
        temperatureSensor2NotAssemble (210),
        extend1TemperatureSensor1NotAssemble (211),
        extend1TemperatureSensor2NotAssemble (212),
        bmm1CommunicationFault  (213),
        bmm2CommunicationFault  (214),
