-- RU          OBJECT IDENTIFIER ::= { AU 30 }       
       -- 1.3.6.1.4.1.15921.60.2.30.1	
       ruDeviceInfoTable    OBJECT-TYPE
              SYNTAX  SEQUENCE OF RUDeviceInfoEntry
              ACCESS  not-accessible
              STATUS  current
              DESCRIPTION
                  "Device  Infomation of the RU connected to the EU 1-1."
              ::= { RU   1 }


		ruDeviceInfoEntry OBJECT-TYPE
		              SYNTAX  RUDeviceInfoEntry
		              ACCESS  not-accessible
		              STATUS  current
		              DESCRIPTION
		                  "An entry in the table about Device  Infomation of RU."
		              INDEX   { ruDeviceInfoIndex }
		              ::= { ruDeviceInfoTable    1 }
		
		
		RUDeviceInfoEntry::=
		      SEQUENCE {  
		              ruDeviceInfoIndex    INTEGER,
		              ruConnectEuPortNum  DisplayString,
		              ruEquipmentModel     DisplayString,
		              ruEquipmentSN        DisplayString,
		              ruSiteInfo           DisplayString,
		              ruTemperature        INTEGER,
		              ruFirmwareversion    DisplayString,
		              ruHardwareversion    INTEGER,
		              ruDCVoltage          INTEGER,
		              ruPowerConsumption   INTEGER, 
		              ruSoftwareReset      INTEGER,
		              ruRFSwitch1          INTEGER,
		              ruDlPwrOut1          Float,
		              ruUlPwrIn1           Float,
		              ruRFSwitch2          INTEGER,
		              ruDlPwrOut2          Float,
		              ruUlPwrIn2           Float,
		              ruRFSwitch3          INTEGER,
		              ruDlPwrOut3          Float,
		              ruUlPwrIn3           Float,
		              ruRFSwitch4          INTEGER,
		              ruDlPwrOut4          Float,
		              ruUlPwrIn4           Float, 
		              ruRFSwitch5          INTEGER,
		              ruDlPwrOut5          Float,
		              ruUlPwrIn5           Float,
		              ruRFSwitch6          INTEGER,
		              ruDlPwrOut6          Float,
		              ruUlPwrIn6           Float,
		              ruRFSwitch7          INTEGER,
		              ruDlPwrOut7          Float,
		              ruUlPwrIn7           Float,
		              ruRFSwitch8          INTEGER,
		              ruDlPwrOut8          Float,
		              ruUlPwrIn8           Float,
		              ruRFSwitch9          INTEGER,
		              ruDlPwrOut9          Float,
		              ruUlPwrIn9           Float,
		              ruRFSwitch10          INTEGER,
		              ruDlPwrOut10          Float,
		              ruUlPwrIn10           Float,
		              ruRFSwitch11          INTEGER,
		              ruDlPwrOut11          Float,
		              ruUlPwrIn11           Float,
		              ruRFSwitch12          INTEGER,
		              ruDlPwrOut12          Float,
		              ruUlPwrIn12           Float, 
		              ruSFPTemperature-1   INTEGER,
		              ruSFPTxPower-1       Float,
		              ruSFPRxPower-1       Float,
		              ruSFPTemperature-2   INTEGER,
		              ruSFPTxPower-2       Float,
		              ruSFPRxPower-2       Float		              
		}  
		
