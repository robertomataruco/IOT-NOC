       ru10GDeviceInfoTable    OBJECT-TYPE
              SYNTAX  SEQUENCE OF RU10GDeviceInfoEntry
              ACCESS  not-accessible
              STATUS  current
              DESCRIPTION
                  "Device  Infomation of the DxRU10G connected to the DEU 1-1."
              ::= { RU10G   1 }


		ru10GDeviceInfoEntry OBJECT-TYPE
		              SYNTAX  RU10GDeviceInfoEntry
		              ACCESS  not-accessible
		              STATUS  current
		              DESCRIPTION
		                  "An entry in the table about Device  Infomation of ru."
		              INDEX   { ru10GDeviceInfoIndex }
		              ::= { ru10GDeviceInfoTable    1 }
		
		
		RU10GDeviceInfoEntry::=
		      SEQUENCE {  
		              ru10GDeviceInfoIndex    INTEGER,
		              ru10GConnectDeuPortNum  DisplayString,
		              ru10GEquipmentModel     DisplayString,
		              ru10GEquipmentSN        DisplayString,
		              ru10GSiteInfo           DisplayString,
		              ru10GTemperature        INTEGER,
		              ru10GFirmwareversion    DisplayString,
		              ru10GHardwareversion    INTEGER,
		              ru10GDCVoltage          INTEGER,
		              ru10GPowerConsumption   INTEGER, 
		              ru10GSoftwareReset      INTEGER,
		              ru10GRFSwitch1          INTEGER,
		              ru10GDlPwrOut1          Float,
		              ru10GUlPwrIn1           Float,
		              ru10GRFSwitch2          INTEGER,
		              ru10GDlPwrOut2          Float,
		              ru10GUlPwrIn2           Float,
		              ru10GRFSwitch3          INTEGER,
		              ru10GDlPwrOut3          Float,
		              ru10GUlPwrIn3           Float,
		              ru10GRFSwitch4          INTEGER,
		              ru10GDlPwrOut4          Float,
		              ru10GUlPwrIn4           Float,  
		              	              
		              ru10GSFPTemperature-1   INTEGER,
		              ru10GSFPTxPower-1       Float,
		              ru10GSFPRxPower-1       Float, 
		           		              
		              ru10GSFPTemperature-2   INTEGER,
		              ru10GSFPTxPower-2       Float,
		              ru10GSFPRxPower-2       Float,
		           		                
		              ru10GSFPTemperature-3   INTEGER,
		              ru10GSFPTxPower-3       Float,
		              ru10GSFPRxPower-3       Float,
		     		              
		}  
		
		ru10GDeviceInfoIndex  OBJECT-TYPE
		    SYNTAX              INTEGER 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "RU Num ."
		::= { ru10GDeviceInfoEntry 1 }
		
		ru10GConnectDeuPortNum   OBJECT-TYPE
		    SYNTAX              DisplayString 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "The RU Connected to DEU Port Num."
		::= { ru10GDeviceInfoEntry 2 }	
		
		ru10GEquipmentModel   OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "RU Equipment Model."
		::= { ru10GDeviceInfoEntry 3 }
		
		ru10GEquipmentSN      OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "RU Equipment Serial No."
		::= { ru10GDeviceInfoEntry 4 }
		
		ru10GSiteInfo         OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-write
		    STATUS              current
		    DESCRIPTION
		                        "RU Site Info."
		::= { ru10GDeviceInfoEntry 5 }
		
		ru10GTemperature      OBJECT-TYPE
		    SYNTAX              INTEGER
		    UNITS               "C" 
		    MAX-ACCESS          read-only
		    STATUS              current
