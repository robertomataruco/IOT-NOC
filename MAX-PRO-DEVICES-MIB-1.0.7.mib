        UpdateSftpTransactionStatus OBJECT-TYPE
	        SYNTAX        INTEGER {
	        				sftp-not-configured(1),
	        				sftp-ready(2),
	        				in-progress(3),
	        				swap-inprogress(4),
	        				swap-rebooting(5),
	        				swap-failed(6)	
	        			  }
	        MAX-ACCESS    read-only
	        STATUS        current
	        DESCRIPTION   "ONE Software update status"
        ::= { UpdateTransaction 1 }
        
        UpdateSftpTransactionAddress OBJECT-TYPE
	        SYNTAX        DisplayString
	        MAX-ACCESS    read-write
	        STATUS        current
	        DESCRIPTION   "ONE Software update SFTP server address"
        ::= { UpdateTransaction 2 }
        
        UpdateSftpTransactionUser OBJECT-TYPE
	        SYNTAX        DisplayString (SIZE (1..20))
	        MAX-ACCESS    read-write
	        STATUS        current
	        DESCRIPTION   "ONE Software update SFTP user"
        ::= { UpdateTransaction 3 }
        
		UpdateSftpTransactionPassword OBJECT-TYPE
	        SYNTAX        DisplayString (SIZE (1..20))
	        MAX-ACCESS    read-write
	        STATUS        current
	        DESCRIPTION   "ONE Software update SFTP password"
        ::= { UpdateTransaction 4 }
        
		UpdateSftpTransactionFileName OBJECT-TYPE
	        SYNTAX        DisplayString (SIZE (5..128))
	        MAX-ACCESS    read-write
	        STATUS        current
	        DESCRIPTION   "ONE Software update SFTP file name."
        ::= { UpdateTransaction 5 }

		UpdateSwPckAction OBJECT-TYPE
	        SYNTAX        INTEGER {
	        				download-start(1)
	        			  }
	        MAX-ACCESS    read-write
	        STATUS        current
	        DESCRIPTION   "ONE Software update action write only"
        ::= { UpdateTransaction 6 } 
        
        UpdateSftpTransactionProgress OBJECT-TYPE
	        SYNTAX        INTEGER(0..100)
	        MAX-ACCESS    read-only
	        STATUS        current
	        DESCRIPTION   "ONE Software update package progress"
        ::= { UpdateTransaction 7 }      
        
		UpdateSftpTransactionFailReason OBJECT-TYPE
	        SYNTAX        DisplayString (SIZE (1..64))
	        MAX-ACCESS    read-only
	        STATUS        current
	        DESCRIPTION   "ONE Software update fail reason."
        ::= { UpdateTransaction 8 }
        
