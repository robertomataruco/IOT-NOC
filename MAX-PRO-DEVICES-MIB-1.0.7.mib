		-- DCU ---------------------------------------------------------------------- 
--dcuDevInfo    OBJECT IDENTIFIER ::= { maSDCU 50 }  
	-- 1.3.6.1.4.1.15921.60.50.1
	   sauDevInfo      OBJECT IDENTIFIER ::= { SAU 1 } 
	   
         -- 1.3.6.1.4.1.15921.60.50.1.1
		sauDevInfoTable    OBJECT-TYPE
              SYNTAX  SEQUENCE OF sAUDevInfoEntry
              ACCESS  not-accessible
              STATUS  current
              DESCRIPTION
                  "Slaver AU Device Information."
              ::= { sauDevInfo   1 }

    	sauDevInfoEntry OBJECT-TYPE
	              SYNTAX  sAUDevInfoEntry
	              ACCESS  not-accessible
	              STATUS  current
	              DESCRIPTION
	                  "An entry in the table about Device Infomation."
	              INDEX   { sauDevInfoIndex }
	              ::= { sauDevInfoTable    1 }   
	    
	    sAUDevInfoEntry::=
		      	  SEQUENCE {  
		              sauDevInfoIndex                   INTEGER, 
		              sauConnectDcuPortNum              DisplayString,
					  sauID                             INTEGER,
					  sauEquipmentModel                 DisplayString,
					  sauEquipmentMode                  INTEGER,
					  sauEquipmentSN                    DisplayString, 
					  sauFirmwareVersion                DisplayString,
					  sauSiteInfo                       DisplayString,
					  sauEquipmentTemperature           INTEGER,
					  sauHardwareVersion                INTEGER,
					  sauFanSpeed                       INTEGER,
					  sauDateTime                       DisplayString,  
					  sauSystemMaxDelay                 INTEGER,
					  sauLongitude                      DisplayString,
					  sauLatitude                       DisplayString,
                      dcuHardwareReset                   INTEGER,
                      dcuSoftwareReset                   INTEGER,
		}  

	    sauDevInfoIndex          OBJECT-TYPE
		    SYNTAX              INTEGER
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "Slaver DCU Device Infomation Index."
		::= { sauDevInfoEntry 1 }
         
         sauConnectDcuPortNum   OBJECT-TYPE
		    SYNTAX              DisplayString 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "The Slaver DCU Connected to Master DCU Port Num."
		::= { sauDevInfoEntry 2 }	
     
		sauID                   OBJECT-TYPE
            SYNTAX              INTEGER
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Index - system define."
        ::= { sauDevInfoEntry 3 }
		
		sauEquipmentModel       OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Equipment Model."
        ::= { sauDevInfoEntry 4 }
        
        sauEquipmentMode       OBJECT-TYPE
            SYNTAX              INTEGER
            {
            	primarily(0),
				secondary(1),
            }
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Equipment Model."
        ::= { sauDevInfoEntry 5 }
        
        sauEquipmentSN          OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Equipment Serial No."
        ::= { sauDevInfoEntry 6 } 
        
         sauFirmwareVersion      OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Firmware Version."
        ::= { sauDevInfoEntry 7 }

        
        sauSiteInfo             OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "Site Info."
        ::= { sauDevInfoEntry 8 }
        
        sauEquipmentTemperature OBJECT-TYPE
            SYNTAX              INTEGER
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Equipment Temperature."
        ::= { sauDevInfoEntry 9 }
        
        sauHardwareVersion      OBJECT-TYPE
            SYNTAX              INTEGER
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Hardware Version."
        ::= { sauDevInfoEntry 10 }
        
        sauFanSpeed             OBJECT-TYPE    	
            SYNTAX              INTEGER
            UNITS               "r/min" 
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Fan Speed."
        ::= { sauDevInfoEntry 11 }
        
        sauDateTime             OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Device Date Time."
        ::= { sauDevInfoEntry 12 }
        
        sauSystemMaxDelay       OBJECT-TYPE
            SYNTAX              INTEGER 
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "Slaver DCU System Max Delay."
        ::= { sauDevInfoEntry 13 }            
        
        sauLongitude           OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "Longitude."
        ::= { sauDevInfoEntry 14 }
        
        sauLatitude             OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "Latitude."
        ::= { sauDevInfoEntry 15 }                    

        sauHardwareReset        OBJECT-TYPE
            SYNTAX              INTEGER
            {
        				reset(1)
			} 
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Hardware Reset."
        ::= { sauDevInfoEntry 16 }
        
        sauSoftwareReset        OBJECT-TYPE
            SYNTAX              INTEGER
            {
        				reset(1)
			} 
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "Slaver DCU Software Reset."
        ::= { sauDevInfoEntry 17 }    
	    
		
