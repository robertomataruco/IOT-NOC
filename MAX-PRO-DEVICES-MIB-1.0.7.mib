-- RIU ----------------------------------------------------------------------
-- slaverRIU          OBJECT IDENTIFIER ::= { maDCU 10 }      
		
		sauRIU     OBJECT IDENTIFIER ::= { SAU 4 }		
		
		-- 1.3.6.1.4.1.15921.60.2.10.1
		sriuInfoTable    OBJECT-TYPE
              SYNTAX  SEQUENCE OF sRiuInfoEntry
              ACCESS  not-accessible
              STATUS  current
              DESCRIPTION
                  "Device  Infomation of the RIU 1-16."
              ::= { sauRIU   1 }


		sriuInfoEntry  OBJECT-TYPE
		              SYNTAX  sRiuInfoEntry
		              ACCESS  not-accessible
		              STATUS  current
		              DESCRIPTION
		                  "An entry in the table about Device  Infomation of RIU."
		              INDEX   { sriuIndex }
		              ::= { sriuInfoTable    1 }
		
		sRiuInfoEntry::=
		      SEQUENCE {  
		              sriuIndex             INTEGER,
		              sriuEquipmentModel    DisplayString,
		              sriuEquipmentSN       DisplayString,
		              sriuSiteInfo          DisplayString,
		              sriuFirmwareversion   DisplayString,
		              sriuHardwareversion   INTEGER,
		              sriuBandInfo          INTEGER,
		              sriuCombinerMode      INTEGER,
		              sriuTemperature       INTEGER,
		              sriuBandSwitch1       INTEGER,
		              sriuBandSwitch2       INTEGER,
		              sriuBandSwitch3       INTEGER,
		              sriuBandSwitch4       INTEGER,
		              sriuBandSwitch5       INTEGER,
		              sriuBandSwitch6       INTEGER,
		              sriuBandSwitch7       INTEGER,
		              sriuBandSwitch8       INTEGER,
		              sriuDlPwrIn1          Float,
		              sriuDlPwrIn2          Float,
		              sriuDlPwrIn3          Float, 
		              sriuDlPwrIn4          Float,
		              sriuDlPwrIn5          Float,
		              sriuDlPwrIn6          Float,
		              sriuDlPwrIn7          Float, 
		              sriuDlPwrIn8          Float,		              
		              sriuReset             INTEGER,		              
		}  
		
		sriuIndex                OBJECT-TYPE
		    SYNTAX              INTEGER 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "RIU Num ."
		::= { sriuInfoEntry 1 }
		
		sriuEquipmentModel       OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "RIU Equipment Model."
        ::= { sriuInfoEntry 2 }
        
        sriuEquipmentSN          OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "RIU Equipment Serial No."
		::= { sriuInfoEntry 3 }
		
		sriuSiteInfo             OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-write
		    STATUS              current
		    DESCRIPTION
		                        "riuSiteInfo."
		::= { sriuInfoEntry 4 }
		
		sriuFirmwareversion      OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
