-- EU ----------------------------------------------------------------------
-- EU          OBJECT IDENTIFIER ::= { AU 20 }  
		
		-- 1.3.6.1.4.1.15921.60.2.20.1
		euDeviceInfoTable    OBJECT-TYPE
              SYNTAX  SEQUENCE OF EuDeviceInfoEntry
              ACCESS  not-accessible
              STATUS  current
              DESCRIPTION
                    "Device  Infomation of the EU 1-16.
                    Index 1~4 is equal to EU1-1~EU1-4.
                    Index 5~8 is equal to EU2-1~EU2-4.
                    Index 9~12 is equal to EU3-1~EU3-4.
                    Index 13~16 is equal to EU4-1~EU4-4."
              ::= { EU   1 }


		euDeviceInfoEntry OBJECT-TYPE
		              SYNTAX  EuDeviceInfoEntry
		              ACCESS  not-accessible
		              STATUS  current
		              DESCRIPTION
		                  "An entry in the table about Device  Infomation of EU."
		              INDEX   { euDeviceInfoIndex }
		              ::= { euDeviceInfoTable    1 }
		
		
		EuDeviceInfoEntry::=
		      SEQUENCE {  
		              euDeviceInfoIndex   INTEGER,
		              euTopologyLocation  DisplayString,
		              euEquipmentModel    DisplayString,
		              euCPRIRate          INTEGER,
		              euEquipmentSN       DisplayString,		           
		              euSiteInfo          DisplayString,
		              euTemperature       INTEGER,
		              euFirmwareversion   DisplayString,
		              euHardwareversion   INTEGER,
		              euFanSpeed          INTEGER,
		              euHardwareReset     INTEGER,
		              euSoftwareReset     INTEGER,		            
		}  
		
		euDeviceInfoIndex      OBJECT-TYPE
		    SYNTAX              INTEGER 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "EU Num ."
		::= { euDeviceInfoEntry 1 }
		
		euTopologyLocation     OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "Location of the EU in the topology, eg: EU1-1 "
        ::= { euDeviceInfoEntry 2 }
		
		euEquipmentModel       OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "EU Equipment Model."
        ::= { euDeviceInfoEntry 3 }
        
        euCPRIRate             OBJECT-TYPE
		    SYNTAX              INTEGER
		    {
        				eu-25G(0),
        				eu-10G(1)
			} 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "EU Equipment Mode."
		::= { euDeviceInfoEntry 4 }
		
		euEquipmentSN          OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "EU Equipment Serial No."
		::= { euDeviceInfoEntry 5 }
		
		euSiteInfo          OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-write
		    STATUS              current
		    DESCRIPTION
		                        "EU Site Info."
		::= { euDeviceInfoEntry 6 }
        
        euTemperature          OBJECT-TYPE
		    SYNTAX              INTEGER
		    UNITS               "C"
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "EU Temperature."
		::= { euDeviceInfoEntry 7 }
		
		euFirmwareversion      OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "EU Firmware Version."
        ::= { euDeviceInfoEntry 8 }
        
        euHardwareversion      OBJECT-TYPE
            SYNTAX              INTEGER
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "EU Hardware Version."
        ::= { euDeviceInfoEntry 9 }
		
		euFanSpeed             OBJECT-TYPE
		    SYNTAX              INTEGER
		    UNITS               "r/min"
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "EU Fan Speed."
		::= { euDeviceInfoEntry 10 }
		
		euHardwareReset        OBJECT-TYPE
            SYNTAX              INTEGER
            {
        				reset(1)
			} 
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "EU Hardware Reset."
        ::= { euDeviceInfoEntry 11 }
        
        euSoftwareReset        OBJECT-TYPE
            SYNTAX              INTEGER
            {
        				reset(1)
			} 
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "EU Software Reset."
        ::= { euDeviceInfoEntry 12 }
		
		
		
