-- A-POI ----------------------------------------------------------------------
-- maA-POI          OBJECT IDENTIFIER ::= { AU 10 }      
		
		--
		-- 1.3.6.1.4.1.15921.60.2.10.1
		a-poiInfoTable    OBJECT-TYPE
              SYNTAX  SEQUENCE OF a-poiInfoEntry
              ACCESS  not-accessible
              STATUS  current
              DESCRIPTION
                  "Device  Infomation of the A-POI 1-16."
              ::= { A-POI   1 }


		a-poiInfoEntry  OBJECT-TYPE
		              SYNTAX  a-poiInfoEntry
		              ACCESS  not-accessible
		              STATUS  current
		              DESCRIPTION
		                  "An entry in the table about Device  Infomation of A-POI."
		              INDEX   { a-poiIndex }
		              ::= { a-poiInfoTable    1 }
		
		a-poiInfoEntry::=
		      SEQUENCE {  
		              a-poiIndex             INTEGER,
		              a-poiEquipmentModel    DisplayString,
		              a-poiEquipmentSN       DisplayString,
		              a-poiSiteInfo          DisplayString,
		              a-poiFirmwareversion   DisplayString,
		              a-poiHardwareversion   INTEGER,
		              a-poiBandInfo          INTEGER,
		              a-poiCombinerMode      INTEGER,
		              a-poiTemperature       INTEGER,
		              a-poiBandSwitch1       INTEGER,
		              a-poiBandSwitch2       INTEGER,
		              a-poiBandSwitch3       INTEGER,
		              a-poiBandSwitch4       INTEGER,
		              a-poiBandSwitch5       INTEGER,
		              a-poiBandSwitch6       INTEGER,
		              a-poiBandSwitch7       INTEGER,
		              a-poiBandSwitch8       INTEGER,
		              a-poiDlPwrIn1          Float,
		              a-poiDlPwrIn2          Float,
		              a-poiDlPwrIn3          Float, 
		              a-poiDlPwrIn4          Float,
		              a-poiDlPwrIn5          Float,
		              a-poiDlPwrIn6          Float,
		              a-poiDlPwrIn7          Float, 
		              a-poiDlPwrIn8          Float,		              
		              a-poiReset             INTEGER,		              
		}  
		
		a-poiIndex                OBJECT-TYPE
		    SYNTAX              INTEGER 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "A-POI Num ."
		::= { a-poiInfoEntry 1 }
		
		a-poiEquipmentModel       OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "A-POI Equipment Model."
        ::= { a-poiInfoEntry 2 }
        
        a-poiEquipmentSN          OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "A-POI Equipment Serial No."
		::= { a-poiInfoEntry 3 }
		
		a-poiSiteInfo             OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-write
		    STATUS              current
		    DESCRIPTION
		                        "a-poiSiteInfo."
		::= { a-poiInfoEntry 4 }
		
		a-poiFirmwareversion      OBJECT-TYPE
		    SYNTAX              DisplayString
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "A-POI Firmware Version."
		::= { a-poiInfoEntry 5 }
		
		a-poiHardwareversion      OBJECT-TYPE
		    SYNTAX              INTEGER
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "A-POI Hardware Version."
		::= { a-poiInfoEntry 6 }
		
		a-poiBandInfo             OBJECT-TYPE
		    SYNTAX              INTEGER
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "A-POI Band information."
		::= { a-poiInfoEntry 7 }
		
		a-poiCombinerMode         OBJECT-TYPE
		    SYNTAX              INTEGER{ a-poi-2to1(0), a-poi-4to1(1),a-poi-8to1(2)}
		    MAX-ACCESS          read-write
		    STATUS              current
		    DESCRIPTION
		                        "A-POI Combiner Mode."
		::= { a-poiInfoEntry 8 }
		
		a-poiTemperature          OBJECT-TYPE
		    SYNTAX              INTEGER
		    UNITS               "C" 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
