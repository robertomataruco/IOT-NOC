--auDeviceInfo  OBJECT IDENTIFIER ::= { AU 1 }

		-- 1.3.6.1.4.1.15921.60.2.1
        auDeviceInfo  OBJECT IDENTIFIER ::= { AU 1 }
        
		auID                   OBJECT-TYPE
            SYNTAX              INTEGER
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "AU Index - system define."
        ::= { auDeviceInfo 1 }
		
		auEquipmentModel       OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "AU Equipment Model."
        ::= { auDeviceInfo 2 }
        
        auEquipmentMode       OBJECT-TYPE
            SYNTAX              INTEGER
            {
            			primarily(0),
					    secondary(1)
            }
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "AU Equipment Model."
        ::= { auDeviceInfo 3 }
        
        auEquipmentSN          OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
