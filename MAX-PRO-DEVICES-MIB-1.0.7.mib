--
-- MAX-PRO-DEVICES-MIB.mib
--

    MAX-PRO-DEVICES-MIB DEFINITIONS ::= BEGIN
 
        IMPORTS
            OBJECT-TYPE, MODULE-IDENTITY, NOTIFICATION-TYPE            
                FROM SNMPv2-SMI            
            DisplayString,TEXTUAL-CONVENTION            
                FROM SNMPv2-TC;
		       
		Float ::= TEXTUAL-CONVENTION
		    STATUS          current
		    DESCRIPTION     "This type represents a 32-bit (4-octet) IEEE
		                    floating-point number in binary interchange format."
		    REFERENCE       "IEEE Standard for Floating-Point Arithmetic,
		                    Standard 754-2008"
		    SYNTAX          OCTET STRING (SIZE(32))
    
    	-- 1.3.6.1.4.1.15921.60
        max-comflexpro MODULE-IDENTITY 
            LAST-UPDATED "202405091712Z"          
            ORGANIZATION 
                "N/A"
            CONTACT-INFO 
                "N/A"
            DESCRIPTION 
                "This is max-pro devices mib Version: 1.0.7"
            REVISION "202405091712Z"          
            DESCRIPTION 
                "Version 1.0.7"
            ::= { digitalDAS 60 }
--
-- Node definitions
--
    	-- 1.3.6.1.4.1
        enterprises OBJECT IDENTIFIER ::= { iso(1) org(3) dod(6) internet(1) private(4) 1 }
        
        -- 1.3.6.1.4.1.15921
        digitalDAS OBJECT IDENTIFIER ::= { enterprises 15921 }
        
        -- 1.3.6.1.4.1.15921.60.2
        AU          OBJECT IDENTIFIER ::= {max-comflexpro 2 }
        
		-- 1.3.6.1.4.1.15921.60.2.10
		A-POI          OBJECT IDENTIFIER ::= { AU 10 }
		
		-- 1.3.6.1.4.1.15921.60.2.20
        EU          OBJECT IDENTIFIER ::= { AU 20 }
        
        -- 1.3.6.1.4.1.15921.60.2.30
        RU         OBJECT IDENTIFIER ::= { AU 30 } 
        
        -- 1.3.6.1.4.1.15921.60.2.40
        RU10G      OBJECT IDENTIFIER ::= { AU 40 }        
        
        -- 1.3.6.1.4.1.15921.60.2.50
         SAU      OBJECT IDENTIFIER ::= { AU 50 }  
             
        -- 1.3.6.1.4.1.15921.60.2.100       
        UpdateTransaction OBJECT IDENTIFIER ::= { AU 100 }
        
        ConfigTransaction OBJECT IDENTIFIER ::= { AU 101 }
        
        ExportTransaction OBJECT IDENTIFIER ::= { AU 102 } 
        
