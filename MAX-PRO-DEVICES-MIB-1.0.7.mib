-- AU ---------------------------------------------------------------------- 
--auCommInfo    OBJECT IDENTIFIER ::= { AU 2 }        
        -- 1.3.6.1.4.1.15921.60.2.2
        auCommInfo    OBJECT IDENTIFIER ::= { AU 2 }
       
        auIPType               OBJECT-TYPE
            SYNTAX              INTEGER
            {
            			ipv4(0),
            			ipv6(1)
            }
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "AU IP Type."
        ::= { auCommInfo 1 }
        
        auIPAddress            OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "AU IP Address."
        ::= { auCommInfo 2 }
        
        auDefaultGateway       OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "AU Default Gateway."
        ::= { auCommInfo 3 }
        
        auSubnetMask           OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "AU Subnet Mask."
        ::= { auCommInfo 4 }
        
        auIPV6Address          OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "AU IPV6 Address."
        ::= { auCommInfo 5 }
        
        auIPV6SubPreLen        OBJECT-TYPE
            SYNTAX              INTEGER
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "AU IPV6 Subnet Prefix Length."
        ::= { auCommInfo 6 }
        
        auIPV6DefaultGateway   OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-only
            STATUS              current
            DESCRIPTION
                                "AU IPV6 Default Gateway."
        ::= { auCommInfo 7 }
        
        snmpVersion             OBJECT-TYPE
            SYNTAX              INTEGER
            {
            			v2c(0),
					    v3(1)
            }
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "SNMP Protocol Version."
        ::= { auCommInfo 8 }
        
        snmpTrapDestIP          OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "The IP address of the AU Trap Destination."
        ::= { auCommInfo 9 }
        
        snmpTrapPort            OBJECT-TYPE
            SYNTAX              INTEGER
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "AU SNMP Trap Port."
        ::= { auCommInfo 10 }
        
        snmpPort                OBJECT-TYPE
            SYNTAX              INTEGER
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "SNMP UDP Port Number."
        ::= { auCommInfo 11 }
         
        readCommunity           OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "SNMPv2C readCommunity."
        ::= { auCommInfo 12 }
        
        writeCommunity          OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "SNMPv2C writeCommunity."
        ::= { auCommInfo 13 }
        
        snmpUserName            OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "SNMPv3 snmpUserName."
        ::= { auCommInfo 14 }
        
        snmpAuthenAlgorithm     OBJECT-TYPE
            SYNTAX              INTEGER
            {
            			none(0),
            			sha(1),
            			md5(2)
            }
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "SNMPv3 Authentication Algorithm."
        ::= { auCommInfo 15 }
        
		snmpAuthenPassword      OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "SNMPv3 Authentication Password."
        ::= { auCommInfo 16 }
        
        snmpPrivacyAlgorithm    OBJECT-TYPE
            SYNTAX              INTEGER
            {
            			none(0),
            			des(1),
            			aes(2)
            }
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "SNMPv3 Privacy Algorithm."
        ::= { auCommInfo 17 }
        
        snmpPrivacyPassword     OBJECT-TYPE
            SYNTAX              DisplayString
            MAX-ACCESS          read-write
            STATUS              current
            DESCRIPTION
                                "SNMPv3 Privacy Password."
        ::= { auCommInfo 18 }    
        
        snmpHeartbeatInterval  OBJECT-TYPE
		    SYNTAX              INTEGER(1..20)
		    UNITS         		  "min"
		    MAX-ACCESS          read-write 
		    STATUS              current 
		    DESCRIPTION
                        "The SNMP trap heartbeat interval"
		::= { auCommInfo 19 }

		snmpHeartbeatSwitch  OBJECT-TYPE
		    SYNTAX              INTEGER{on(1),off(0)} 
		    MAX-ACCESS          read-write 
		    STATUS              current 
		    DESCRIPTION
                        "The SNMP trap heartbeat swtich"
		::= { auCommInfo 20 }
        
		
-- AU ---------------------------------------------------------------------- 
--auRfInfo    OBJECT IDENTIFIER ::= { AU 3 }         
 
        -- 1.3.6.1.4.1.15921.60.2.3
        auRfInfo      OBJECT IDENTIFIER ::= { AU 3 }
        
        -- 1.3.6.1.4.1.15921.60.2.3.1
		auRfInfoTable    OBJECT-TYPE
              SYNTAX  SEQUENCE OF DcuRfInfoEntry
              ACCESS  not-accessible
              STATUS  current
              DESCRIPTION
                  "AU RF Information  1-16."
              ::= { auRfInfo   1 }


		auRfInfoEntry OBJECT-TYPE
		              SYNTAX  DcuRfInfoEntry
		              ACCESS  not-accessible
		              STATUS  current
		              DESCRIPTION
		                  "An entry in the table about Device  Infomation of RF."
		              INDEX   { auRfInfoIndex }
		              ::= { auRfInfoTable    1 }
		
		DcuRfInfoEntry::=
		      SEQUENCE {  
		              auRfInfoIndex      INTEGER,
					  auDlPwrIn          Float,
					  auUlPwrOut         Float
		}  
		
		auRfInfoIndex          OBJECT-TYPE
		    SYNTAX              INTEGER
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "AU RF Index."
		::= { auRfInfoEntry 1 }
		
		auDlPwrIn              OBJECT-TYPE
		    SYNTAX              Float
		    UNITS               "dBm" 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "AU DL Input Power."
		::= { auRfInfoEntry 2 }
		
		auUlPwrOut             OBJECT-TYPE
		    SYNTAX              Float
		    UNITS               "dBm" 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "AU UL Output Power."
		::= { auRfInfoEntry 3 }
		
		
-- AU ---------------------------------------------------------------------- 
--auSFPInfo    OBJECT IDENTIFIER ::= { AU 4 }          
        -- 1.3.6.1.4.1.15921.60.2.4
        auSFPInfo     OBJECT IDENTIFIER ::= { AU 4 }
        
        -- 1.3.6.1.4.1.15921.60.2.4.1
		auSFPInfoTable    OBJECT-TYPE
              SYNTAX  SEQUENCE OF DcuSFPInfoEntry
              ACCESS  not-accessible
              STATUS  current
              DESCRIPTION
                  "AU SFP Information  A-F,1-8."
              ::= { auSFPInfo   1 }


		auSFPInfoEntry OBJECT-TYPE
		              SYNTAX  DcuSFPInfoEntry
		              ACCESS  not-accessible
		              STATUS  current
		              DESCRIPTION
		                  "An entry in the table about Device  Infomation of SFP."
		              INDEX   { auSFPInfoIndex }
		              ::= { auSFPInfoTable    1 }
		
		DcuSFPInfoEntry::=
		      SEQUENCE {  
		              auSFPInfoIndex     INTEGER,
		              auSFPPortNum       DisplayString,
					  auSFPTemperature   INTEGER,		
					  auSFPTxPower       Float,
					  auSFPRxPower       Float
		}  
		
		auSFPInfoIndex         OBJECT-TYPE
		    SYNTAX              INTEGER 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "SFP Index. The Index 1-6 represent Optical Port A-F. The Index 7-14 represent Optical Port 1-8."
		::= { auSFPInfoEntry 1 }
		
		auSFPPortNum           OBJECT-TYPE
		    SYNTAX              DisplayString 
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "Optical Port A-F and Optical Port 1-8."
		::= { auSFPInfoEntry 2 }
		
		auSFPTemperature       OBJECT-TYPE
		    SYNTAX              INTEGER
		    UNITS               "C"  
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "AU SFP Temperature."
		::= { auSFPInfoEntry 3 }
		
		auSFPTxPower           OBJECT-TYPE
		    SYNTAX              Float
		    UNITS               "dBm"  
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "AU SFP Tx Power."
		::= { auSFPInfoEntry 4 }
		
		auSFPRxPower           OBJECT-TYPE
		    SYNTAX              Float
		    UNITS               "dBm"  
		    MAX-ACCESS          read-only
		    STATUS              current
		    DESCRIPTION
		                        "AU SFP Rx Power."
		::= { auSFPInfoEntry 5 }		
		
		
