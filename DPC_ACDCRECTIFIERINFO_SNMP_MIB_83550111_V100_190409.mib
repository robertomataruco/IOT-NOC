    rectifierOutputVoltage OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Output voltage of rectifier.
         The actual value = The receive data/100.
         The unit of actual value is volt.
        "
    ::= { acdcRectifierInfoEntry 2 }
    
    rectifierOutputCurrent OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Output current of rectifier.
         The actual value = The receive data/100.
         The unit of actual value is ampere.
         "
    ::= { acdcRectifierInfoEntry 3 }
    
    rectifierOutputCurrentLimit OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Output current limit of rectifier.
         The actual value = The receive data/100.
         The unit of actual value is ampere.
         "
    ::= { acdcRectifierInfoEntry 4 }
    
    rectifierOutputSettingVoltage OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Output setting voltage of rectifier.
         The actual value = The receive data/100.
         The unit of actual value is volt.
         "
    ::= { acdcRectifierInfoEntry 5 }
    
    rectifierInputVoltage OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
