DPC-DISTRIBUTED-ACDCRECTIFIERINFO-MIB DEFINITIONS ::= BEGIN

IMPORTS
    NOTIFICATION-TYPE, OBJECT-TYPE, MODULE-IDENTITY, 
    enterprises, Counter32, Integer32
        FROM SNMPv2-SMI
    NOTIFICATION-GROUP
        FROM SNMPv2-CONF
    DisplayString
        FROM SNMPv2-TC;

dpc MODULE-IDENTITY
    LAST-UPDATED "201904091848Z"
    ORGANIZATION 
        "Beijing Dynamic Power Shenzhen R&D(DPC)"
    CONTACT-INFO 
        "Beijing Dynamic Power Shenzhen R&D(DPC).
              Postal: 518000
              Shenzhen,China
              web:  www.dpc.com.cn"
    DESCRIPTION 
        "dpcDistributedPower is 10 of dpc.
         Branch overview:
         acDistribution is the branch of dpcDistributedPower`s node,which branch will be 1.
		 rectifier is the branch of dpcDistributedPower`s node,which branch will be 2.
		 dcDistribution is the branch of dpcDistributedPower`s node,which branch will be 3.
		 systemAlarm is the branch of dpcDistributedPower`s node,which branch will be 4. 
		 solarController is the branch of dpcDistributedPower`s node,which branch will be 5.
		 dcdcConverter is the branch of dpcDistributedPower`s node,which branch will be 6.
        "

    REVISION "201904091849Z"
    DESCRIPTION 
        "Version:V100
         First revision.
        
        
        Author Black"
                 
::= { enterprises 39553 }
    
--
-- Node definitions
--
---------------------------------------------------------------
--  DPC Distribution Information{ DPC 10 }
--------------------------------------------------------------- 
    -- 1.3.6.1.4.1.39553.10
    dpcDistributedPower OBJECT IDENTIFIER ::= { dpc 10 }

---------------------------------------------------------------
--  AC Distribution Information{ dpcDistributedPower 1 }
---------------------------------------------------------------         
    -- 1.3.6.1.4.1.39553.10.1
    --acDistribution OBJECT IDENTIFIER ::= { dpcDistributedPower 1 }   
    rectifier OBJECT IDENTIFIER ::= { dpcDistributedPower 2 }
        
    -- 1.3.6.1.4.1.39553.10.2.1
    --analog OBJECT IDENTIFIER ::= { rectifier 1 }          
        -- 1.3.6.1.4.1.39553.10.2.5
        cabinetInfo OBJECT IDENTIFIER ::= { rectifier 5 }
  -- 1.3.6.1.4.1.39553.10.2.5.1
    rectifierNumber  OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION 
        "The total number of rectifier."
    ::= { cabinetInfo 1  }
  -- 1.3.6.1.4.1.39553.10.2.5.2
    rectifierPower   OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION 
        "The total power of all rectifier.
         The actual value = The receive data/1000.
         The unit of actual value is KW."
    ::= { cabinetInfo 2  }
------------------------------------------------------------
-- ACDC Rectifier information table { cabinetInfo 3 }
------------------------------------------------------------

acdcRectifierInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF ACDCRectifierInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "
        Table holding information about the currently ACDC Rectifier."
    ::= { cabinetInfo 3 }

acdcRectifierInfoEntry OBJECT-TYPE
    SYNTAX ACDCRectifierInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "
        An entry (conceptual row) in the acdcRectifierInfoTable."
    INDEX { rectifierIndex }
    ::= { acdcRectifierInfoTable 1 }

ACDCRectifierInfoEntry ::= SEQUENCE {
        rectifierIndex INTEGER,
        rectifierOutputVoltage INTEGER,
