    ::= { acdcRectifierInfoEntry 8 }
    
    rectifierInputVoltageUca OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Input voltage Uca of rectifier.
         The actual value = The receive data/100.
         The unit of actual value is volt.
         "
    ::= { acdcRectifierInfoEntry 9 }
    
    rectifierAmbientTemperature OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Ambient Temperature of rectifier.
         The actual value = The receive data/100.
         The unit of actual value is degree."
    ::= { acdcRectifierInfoEntry 10 }
    
    rectifierPrimaryHotPointTemperature OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Primary Hot Point Temperature of rectifier.
         The actual value = The receive data/100.
         The unit of actual value is degree."
    ::= { acdcRectifierInfoEntry 11 }
    
    rectifierSecondHotPointTemperature OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Second Hot Point Temperature of rectifier.
         The actual value = The receive data/100.
         The unit of actual value is degree."
    ::= { acdcRectifierInfoEntry 12 }
    
    rectifierRunTime OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Run time of rectifier.
         The actual value = The receive data/100.
         The unit of actual value is hour."
    ::= { acdcRectifierInfoEntry 13 }
    
    rectifierType OBJECT-TYPE
    SYNTAX  INTEGER {typeNone (0),
                    type27V1500W (271500),
                    type48V1000W (481000),
                    type48V6000W (486000),
                    type48V3000W (483000),
                    type48V2900W (482900),
                    type48V2000W (482000),
                    type48V1160W (481160),
                    type48V1100W (481100),
                    type48V290W (48290),
                    type240V11600W (24011600),
                    type336V11600W (33611600)
                    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Type of rectifier.
        Receive data is 271500:27V 1500W;
        Receive data is 486000:48V 6000W;
        Receive data is 483000:48V 3000W;
        Receive data is 482900:48V 2900W;
        Receive data is 482000:48V 2000W;
        Receive data is 481160:48V 1160W;
        Receive data is 481100:48V 1100W;
        Receive data is 48290:48V 290W;
        Receive data is 24011600:240V 11600W;
        Receive data is 33611600:336V 11600W.
        "
    ::= { acdcRectifierInfoEntry 14 }
    
    rectifierState OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
         The state of rectifier.
        The bit0 to bit31 for the receive data,each bit mean one sate.
        Bit30:0 mean rectifier is ON,1 mean rectifier is OFF;
        Bit15:1 mean rectifier output current limit,
        0 means rectifier no output current limit.
        Other bits reserve."
    ::= { acdcRectifierInfoEntry 15 }
    
    rectifierAlarmStatus1 OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
         The alarm status of rectifier.
        Each bit mean a alarm,when corresponding bit is 1 indicate have an alarm,
        corresponding bit is 0 indicate no alarm.
        bit0:rectifier current sample fault;bit1:rectifier primary-side circuit short;
        bit2:mutiple rectifier no output;bit3:single rectifier no output;
        bit4:rectifier outside circuit short;bit5:rectifier PFC imbalance;
        bit6:rectifier identify fault;bit7:rectifier lost;
        bit8:rectifier current sharing slightly fault;bit9:rectifier current sharing severe fault;
        bit10:rectifier no position;bit11:rectifier output over current;
        bit12:rectifier E2PROM fault;bit13:rectifier CAN communication fault;
        bit14:rectifier second side communication fault;bit15:rectifier primary side communication fault;
        bit16:rectifier fan fault;bit17:rectifier start resistor break;
        bit18:rectifier PFC over voltage protection;bit19:rectifier PFC under voltage protection;
        bit20:rectifier AC imbalance;bit21:rectifier AC lose phase;
        bit22:rectifier AC under voltage protection;bit23:rectifier AC over voltage protection;
        bit24:rectifier internal circuit short;bit25:rectifier output fuse break;
        bit26:rectifier secondary hot point over temperature;bit27:rectifier primary hot point over temperature;
        bit28:rectifier ambient over temperature;bit29:rectifier output under voltage protection;
        bit30:rectifier output over voltage protection;bit31:rectifier internal over voltage protection."
    ::= { acdcRectifierInfoEntry 16 }
    
    rectifierAlarmStatus2 OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
         The alarm status 2 of rectifier.
        Each bit mean a alarm,when corresponding bit is 1 indicate have an alarm,
        corresponding bit is 0 indicate no alarm.
        bit0:rectifier PFC short;
        bit1:rectifier OVSD;
        bit2:rectifier Security Code Error;
        bit3--bit31:none."
    ::= { acdcRectifierInfoEntry 17 }
    
    rectifierBarcode OBJECT-TYPE
    SYNTAX INTEGER
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "
        Barcode of rectifier.
         "
    ::= { acdcRectifierInfoEntry 18 }
    
    rectifierPhaseSet OBJECT-TYPE
    SYNTAX INTEGER {
        none    (0),
        phaseA  (1),
        phaseB  (2),
        phaseC  (3)
    }
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "
        Which phase is the rectifier allocated to.
        none    (0),
        Phase A (1),
        Phase B (2),
        Phase C (3),
        "
    ::= { acdcRectifierInfoEntry 19 }
