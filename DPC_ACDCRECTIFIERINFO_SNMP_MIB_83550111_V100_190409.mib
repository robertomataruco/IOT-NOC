    -- 1.3.6.1.4.1.39553.10.2.8.1
    acdcRectifierType OBJECT-TYPE
    SYNTAX INTEGER {
        can (0),
        rs485 (1)
    }
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "The type of ACDC rectifier."
    ::= { rectifierParameter 1 }        
    -- 1.3.6.1.4.1.39553.10.2.8.2
    acdcRectifierWalkinVoltage OBJECT-TYPE
    SYNTAX INTEGER(4200..5350)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "The walk-in valtage of ACDC rectifier.
         The actual value = The receive data/100.
         Unit is V."    
    ::= { rectifierParameter 2 }
    -- 1.3.6.1.4.1.39553.10.2.8.3
    acdcRectifierWalkinTime OBJECT-TYPE
    SYNTAX INTEGER(0..12000)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "The walk-in time of ACDC rectifier.
         The actual value = The receive data/100.
         Unit is S."    
    ::= { rectifierParameter 3 }
    -- 1.3.6.1.4.1.39553.10.2.8.4
    acdcRectifierStartupDelayTime OBJECT-TYPE
    SYNTAX INTEGER(0..60000)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION 
        "The start-up delay time of ACDC rectifier.
         The actual value = The receive data/100.
         Unit is S."    
    ::= { rectifierParameter 4 }  
