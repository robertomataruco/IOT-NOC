        rectifierType INTEGER,
        rectifierState INTEGER,
        rectifierAlarmStatus1 INTEGER,
        rectifierAlarmStatus2 INTEGER,
        rectifierBarcode INTEGER,
        rectifierPhaseSet INTEGER
    }

